            "label": "2026-04-13_21-30-37",
            "content": "package main\n\nimport (\n\t\"fmt\"\n)\n\nfunc arvore(pen *Pen, galho float64) {\n\tif galho < 2 {\n\t\treturn\n\t}\n\n\tpen.Walk(galho)\n\tpen.Left(30)\n\tarvore(pen, galho*0.7)\n\tpen.Right(60)\n\tarvore(pen, galho*0.7)\n\tpen.Left(30)\n\tpen.Walk(-galho)\n\n}\n\nfunc main() {\n\tpen := NewPen(600, 500)\n\tpen.SetLineWidth(0.7)\n\tpen.SetHeading(90)\n\tpen.SetPosition(300, 500)\n\tarvore(pen, 150)\n\tpen.SavePNG(\"tree.png\")\n\tfmt.Println(\"PNG file created successfully.\")\n}\n",
            "lines": "30"
